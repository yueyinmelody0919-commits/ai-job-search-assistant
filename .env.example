# ============================================================
# Melody's AI Colleague Team — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# All services below have free tiers sufficient for this project.
# ============================================================

# --- Google OAuth (for Dashboard Auth) ---
# Create a NEW project at https://console.cloud.google.com
# Enable: Gmail API, Google Sheets API, Google Calendar API
# Create OAuth 2.0 credentials (Web Application type)
# Add redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Service Account (for Gmail, Sheets, Calendar API access) ---
# In the same Google Cloud project, create a Service Account
# OR use OAuth refresh token flow for user-level access
# For OAuth user flow (recommended for personal Gmail):
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google
GOOGLE_REFRESH_TOKEN=

# --- NextAuth.js ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Anthropic (Claude API) ---
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- JSearch (RapidAPI) ---
# Sign up at https://rapidapi.com
# Subscribe to JSearch API (free tier: 500 req/mo)
RAPIDAPI_KEY=

# --- Adzuna ---
# Sign up at https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# --- Apollo.io ---
# Sign up at https://app.apollo.io
# Free: 50 email credits/mo
# Get API key from Settings → API
APOLLO_API_KEY=

# --- Tavily (Web Search) ---
# Sign up at https://tavily.com
# Free tier: 1,000 searches/mo
TAVILY_API_KEY=

# --- Slack Bot Tokens ---
# Create each app at https://api.slack.com/apps
# Enable Socket Mode, get Bot Token + App-Level Token per app
# Bot Token scopes: app_mentions:read, chat:write, im:history, im:read, im:write, files:write
SLACK_SCOUT_BOT_TOKEN=
SLACK_SCOUT_APP_TOKEN=
SLACK_ANALYST_BOT_TOKEN=
SLACK_ANALYST_APP_TOKEN=
SLACK_STRATEGIST_BOT_TOKEN=
SLACK_STRATEGIST_APP_TOKEN=
SLACK_OPS_BOT_TOKEN=
SLACK_OPS_APP_TOKEN=
SLACK_ENGINEER_BOT_TOKEN=
SLACK_ENGINEER_APP_TOKEN=
SLACK_COACH_BOT_TOKEN=
SLACK_COACH_APP_TOKEN=
SLACK_QA_BOT_TOKEN=
SLACK_QA_APP_TOKEN=

# --- Slack Workspace ---
SLACK_TEAM_ID=
SLACK_ACCESS_TOKEN=
SLACK_REFRESH_TOKEN=

# --- GIPHY (for meme engine) ---
# Get free API key at https://developers.giphy.com
GIPHY_API_KEY=

# --- Database ---
DATABASE_URL=file:./data/colleague-team.db

# --- Bot Server (Railway) ---
# Set after Railway deployment
BOT_SERVER_URL=http://localhost:3001

# --- Deployment ---
# Set after Vercel deployment
NEXT_PUBLIC_APP_URL=http://localhost:3000
